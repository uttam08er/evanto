# ============================================================
# FILE: client/.env.example
# PURPOSE: Frontend environment variables.
#          VITE_ prefix is REQUIRED for Vite to expose these to React.
#          Copy this to .env and fill in your values.
#          NEVER expose secret keys here - only public keys!
# ============================================================

# Stripe PUBLISHABLE key (safe to expose - this is NOT the secret key)
# Get from: stripe.com → Developers → API Keys → Publishable key
# It starts with "pk_test_" for testing
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Backend API URL (used if you deploy separately)
# In development, leave blank - Vite proxy handles it
# In production: VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=
