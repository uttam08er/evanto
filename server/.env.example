PORT=5000
NODE_ENV=development

# ---- DATABASE ----
# Get this from MongoDB Atlas: 
# 1. Go to mongodb.com → Create free account
# 2. Create a cluster
# 3. Click "Connect" → "Connect your application"
# 4. Copy the connection string and replace <password> with your DB password
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/evently?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ---- CLOUDINARY (for image uploads) ----
# 1. Go to cloudinary.com → Create free account
# 2. Go to Dashboard → Copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ---- EMAIL (Nodemailer via Gmail) ----
# 1. Go to your Google Account → Security → 2-Step Verification (enable it)
# 2. Then go to Security → App passwords → Create a new app password
# 3. Use that 16-character password here (NOT your Gmail login password)
EMAIL_FROM=yourgmail@gmail.com
EMAIL_PASSWORD=your_16_character_app_password

# ---- STRIPE (for payments) ----
# 1. Go to stripe.com → Create account
# 2. Go to Developers → API Keys
# 3. Copy the "Secret key" (starts with sk_test_ for testing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ---- FRONTEND URL (for CORS and email links) ----
CLIENT_URL=http://localhost:5173
